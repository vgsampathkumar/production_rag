OPENAI_API_KEY=sk-proj-...

# Cross-encoder model (TinyBERT is faster; MiniLM-L-6 is more accurate)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-TinyBERT-L-2-v2
DENSE_K=10
SPARSE_K=10
RERANK_TOP_K=5

# Authentication — get from https://dashboard.clerk.com
# Configure → Developers → API Keys → JWT verification → JWKS URL
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
